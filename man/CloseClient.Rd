\link[sf:sf]{sf} — handy as a \code{boundary} layer for \code{\link[=close_map]{close_map()}} when mapping
a city's blocks or POIs. Free (no API key).
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CloseClient$place_boundary(geoid, output = NULL)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{geoid}}{Census place GEOID.}
      \item{\code{output}}{Override the client's output mode for this call.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    A one-row \link[sf:sf]{sf} polygon (a \link{close_reply} when \code{output} is
\code{'raw'}).
  }
}

\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-CloseClient-isochrone"></a>}}
\if{latex}{\out{\hypertarget{method-CloseClient-isochrone}{}}}
\subsection{\code{CloseClient$isochrone()}}{
  Travel-time contours from a block or a lat/lon point. Give
\code{minutes} for one threshold, or \code{contours} for up to four.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{CloseClient$isochrone(
  block = NULL,
  lon = NULL,
  lat = NULL,
  mode = NULL,
  direction = NULL,
  minutes = NULL,
  contours = NULL,
  format = NULL,
  v = NULL,
  if_none_match = NULL,
  output = NULL
)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{block}}{Origin block GEOID (or give \code{lon} + \code{lat}).}
      \item{\code{lon, lat}}{Origin point, instead of \code{block}.}
      \item{\code{mode}}{"walk", "bike", or "transit".}
      \item{\code{direction}}{"to" (blocks that can reach the origin) or "from".}
      \item{\code{minutes}}{A single threshold (1 to 60).}
      \item{\code{contours}}{Up to four ascending levels, instead of \code{minutes}.}
      \item{\code{format}}{"geojson" (polygons) or "blocks" (a block list).}
      \item{\code{v}}{Optional cache-buster, echoed back.}
      \item{\code{if_none_match}}{An ETag to revalidate for free.}
      \item{\code{output}}{Override the client's output mode for this call.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    An \link[sf:sf]{sf} (contour polygons for geojson, block polygons for
blocks), a data frame in tabular mode, or a \link{close_reply} when \code{output}
is \code{'raw'}.
  }
}

